<Activity x:Class="ForEachSheetX" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:ue="clr-namespace:UiPath.Excel;assembly=UiPath.Excel.Activities" xmlns:ueab="clr-namespace:UiPath.Excel.Activities.Business;assembly=UiPath.Excel.Activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ueab:ForEachSheetX Workbook="{x:Null}">
    <ueab:ForEachSheetX.Body>
      <ActivityAction x:TypeArguments="ue:WorksheetQuickHandle, x:Int32">
        <ActivityAction.Argument1>
          <DelegateInArgument x:TypeArguments="ue:WorksheetQuickHandle" Name="CurrentSheet" />
        </ActivityAction.Argument1>
        <ActivityAction.Argument2>
          <DelegateInArgument x:TypeArguments="x:Int32" Name="CurrentIndex" />
        </ActivityAction.Argument2>
        <Sequence DisplayName="Do" />
      </ActivityAction>
    </ueab:ForEachSheetX.Body>
  </ueab:ForEachSheetX>
</Activity>