      <umabh:HtmlContentArgument FilePath="{x:Null}" HtmlBody="{x:Null}">
        <umabh:HtmlContentArgument.RuntimeImages>
          <scg:Dictionary x:TypeArguments="x:String, InArgument(x:String)" />
