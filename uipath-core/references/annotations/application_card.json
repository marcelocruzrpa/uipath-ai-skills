      "alternatives": [
        {
          "activity": "NApplicationCardOpen",
          "use_instead_when": "You need to launch a browser at a URL rather than attach to an existing one."
        },
        {
          "activity": "NApplicationCardDesktopOpen",
          "use_instead_when": "You need to launch a desktop executable rather than attach to an open window."
        }
      ],
      "tags": [
        "scope",
