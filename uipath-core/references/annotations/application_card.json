        },
        "NApplicationCard.TargetApp": {
          "type": "static_block",
          "content": "TargetApp with Area, BrowserType (auto-detected), Selector, Url, and empty Arguments/FilePath/WorkingDirectory InArguments"
        }
      },
      "conditional_attrs": {},
      "category": "application_card",
      "description": "Open a browser to a URL inside a UI scope and run the body against that browser instance.",
