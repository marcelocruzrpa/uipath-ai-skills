      "alternatives": [
        {
          "activity": "NApplicationCardAttach",
          "use_instead_when": "The browser or app is already running and you only need to attach to its window."
        },
        {
          "activity": "NApplicationCardDesktopOpen",
          "use_instead_when": "The target is a desktop executable launched by file path, not a URL in a browser."
        }
      ],
      "tags": [
        "scope",
        "browser",
        "open"
      ],
      "_routing_review_needed": false
