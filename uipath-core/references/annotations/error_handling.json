{
  "$schema_version": "1.0",
  "module": "error_handling",
  "activities": {
    "TryCatch": {
      "gen_function": "gen_try_catch",
      "element_tag": "TryCatch",
      "hint_size_key": "TryCatch",
      "params": {
        "try_content": {
          "attr": null,
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "string"
        },
        "try_sequence_idref": {
          "attr": null,
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref"
        },
        "id_ref": {
          "attr": "sap2010:WorkflowViewState.IdRef",
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref",
          "note": "Prefixed with 'TryCatch_'"
        },
        "catches": {
          "attr": null,
          "required": false,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "string",
          "note": "List of (exception_type, variable_name, catch_content, catch_sequence_idref) tuples. Default: single s:Exception catch."
        },
        "finally_content": {
          "attr": null,
          "required": false,
          "default": "",
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "string"
        },
        "finally_sequence_idref": {
          "attr": null,
          "required": false,
          "default": "",
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref"
        },
        "display_name": {
          "attr": "DisplayName",
          "required": false,
          "default": "Try Catch",
          "enum": null,
          "escape": "xml",
          "bracket_wrap": false,
          "type": "string"
        }
      },
      "fixed_attrs": {},
      "child_elements": {
        "TryCatch.Try": {
          "type": "sequence",
          "content": "Sequence DisplayName='Try' with try_content and viewstate_block"
        },
        "TryCatch.Catches": {
          "type": "list",
          "content": "Catch x:TypeArguments with ActivityAction, DelegateInArgument, and inner Sequence"
        },
        "TryCatch.Finally": {
          "type": "sequence",
          "content": "Sequence DisplayName='Finally' (only when finally_content is non-empty)"
        }
      },
      "conditional_attrs": {},
      "category": "error_handling",
      "description": "Run a Try block and route any exception to one of several typed Catch handlers, with an optional Finally block that always executes.",
      "use_when": "An expected exception type has a meaningful recovery path (log, fall back, swallow) that should keep the workflow running. Use RetryScope when the failure is a transient external glitch you simply want to retry; use Throw when you want to abort with a typed exception rather than handle one.",
      "alternatives": [
        {
          "activity": "RetryScope",
          "use_instead_when": "The failure is a transient external problem and the right response is to retry the same activity, not to handle a different code path."
        },
        {
          "activity": "Throw",
          "use_instead_when": "You actually want to raise a new exception, not catch one."
        }
      ],
      "tags": [
        "exception",
        "try-catch",
        "handler",
        "finally"
      ],
      "_routing_review_needed": false
    },
    "Throw": {
      "gen_function": "gen_throw",
      "element_tag": "Throw",
      "hint_size_key": "Throw",
      "params": {
        "exception_expression": {
          "attr": "Exception",
          "required": true,
          "default": null,
          "enum": null,
          "escape": "vb_expr",
          "bracket_wrap": true,
          "type": "string"
        },
        "id_ref": {
          "attr": "sap2010:WorkflowViewState.IdRef",
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref"
        },
        "display_name": {
          "attr": "DisplayName",
          "required": false,
          "default": "Throw",
          "enum": null,
          "escape": "xml",
          "bracket_wrap": false,
          "type": "string"
        }
      },
      "fixed_attrs": {},
      "child_elements": {},
      "conditional_attrs": {},
      "note": "Self-closing tag.",
      "category": "error_handling",
      "description": "Raise a new exception built from a VB expression, aborting the current branch with a typed reason.",
      "use_when": "A business-rule violation or unrecoverable condition must stop execution and surface a specific exception type to the caller. Use Rethrow when you want to re-emit the exception that the surrounding TryCatch already caught; use TryCatch when you want to handle, not raise.",
      "alternatives": [
        {
          "activity": "Rethrow",
          "use_instead_when": "You are inside a Catch block and want to forward the original exception unchanged rather than construct a new one."
        }
      ],
      "tags": [
        "exception",
        "throw",
        "abort"
      ],
      "_routing_review_needed": false
    },
    "Rethrow": {
      "gen_function": "gen_rethrow",
      "element_tag": "Rethrow",
      "hint_size_key": null,
      "params": {
        "id_ref": {
          "attr": "sap2010:WorkflowViewState.IdRef",
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref",
          "note": "Prefixed with 'Rethrow_'"
        },
        "display_name": {
          "attr": "DisplayName",
          "required": false,
          "default": "Rethrow",
          "enum": null,
          "escape": "xml",
          "bracket_wrap": false,
          "type": "string"
        }
      },
      "fixed_attrs": {},
      "child_elements": {},
      "conditional_attrs": {},
      "note": "Self-closing tag.",
      "category": "error_handling",
      "description": "Re-emit the exception that the enclosing TryCatch is currently handling, preserving its original type and stack.",
      "use_when": "You are inside a Catch and want to do partial work (logging, cleanup) before letting the same exception bubble up unchanged. Use Throw when you want to raise a different / new exception instead.",
      "alternatives": [
        {
          "activity": "Throw",
          "use_instead_when": "You want to raise a new exception (different type or message), not forward the one you caught."
        }
      ],
      "tags": [
        "exception",
        "rethrow",
        "catch"
      ],
      "_routing_review_needed": false
    },
    "RetryScope": {
      "gen_function": "gen_retryscope",
      "element_tag": "ui:RetryScope",
      "hint_size_key": "RetryScope",
      "params": {
        "display_name": {
          "attr": "DisplayName",
          "required": true,
          "default": null,
          "enum": null,
          "escape": "xml",
          "bracket_wrap": false,
          "type": "string"
        },
        "id_ref": {
          "attr": "sap2010:WorkflowViewState.IdRef",
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref"
        },
        "body_content": {
          "attr": null,
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "string"
        },
        "body_sequence_idref": {
          "attr": null,
          "required": true,
          "default": null,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "id_ref"
        },
        "number_of_retries": {
          "attr": "NumberOfRetries",
          "required": false,
          "default": 3,
          "enum": null,
          "escape": null,
          "bracket_wrap": false,
          "type": "string"
        }
      },
      "fixed_attrs": {
        "LogRetriedExceptions": "{x:Null}",
        "RetriedExceptionsLogLevel": "{x:Null}"
      },
      "child_elements": {
        "RetryScope.ActivityBody": {
          "type": "sequence",
          "content": "ActivityAction with inner Sequence DisplayName='Action'"
        },
        "RetryScope.Condition": {
          "type": "static_block",
          "content": "<ActivityFunc x:TypeArguments=\"x:Boolean\" />"
        }
      },
      "conditional_attrs": {},
      "category": "error_handling",
      "description": "Run the body and re-execute it up to N times when it fails or its condition stays unmet, then surface the final exception.",
      "use_when": "The activity inside is calling something flaky (network call, slow UI, eventual-consistency lookup) where the right response to a transient failure is just to try again. Use TryCatch when the failure has a meaningful alternative code path; do NOT wrap NetHttpRequest (it has its own built-in retry).",
      "alternatives": [
        {
          "activity": "TryCatch",
          "use_instead_when": "On failure you want a different code path (log, fall back, swallow) rather than another attempt."
        }
      ],
      "tags": [
        "retry",
        "transient",
        "scope"
      ],
      "_routing_review_needed": false
    }
  }
}
